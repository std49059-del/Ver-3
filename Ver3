                hero_title: "School Food Ordering", hero_subtitle: "Delicious, Fresh, Delivered straight to your building",
                title_location: "Location Pinning", label_building: "Select Building/Location:",
                label_notes: "Additional Notes (Details):", placeholder_notes: "e.g., In front of Room 302, under the building",
                title_shops: "All 14 Shops", title_cart: "Multi-Shop Cart",
                cart_empty: "Your cart is currently empty", th_item: "Item", th_shop: "Shop",
                th_price: "Price", th_qty: "Qty", th_action: "Action", total_label: "Grand Total:",
                btn_checkout: "Checkout Now", title_tracking: "Order Tracking",
                tracking_timer_text: "Food will arrive in 15 minutes", step_preparing: "Preparing",
                step_cooking: "Cooking", step_delivering: "Delivering", step_completed: "Completed",
                delivery_done_title: "Delivery Completed", delivery_done_desc: "Thank you for ordering!",
                btn_select_menu: "Select Menu", label_spicy: "Spiciness Level:", label_egg: "Add Fried Egg (+10 ฿)",
                label_no_veg: "No Veggies", label_more_noodle: "Extra Noodles (+10 ฿)", btn_add_to_cart: "Add to Cart",
                txt_available: "Available", txt_outofstock: "Out of Stock", opt_no_spicy: "None", opt_mid_spicy: "Medium", opt_high_spicy: "High",
                alert_location: "Please select a delivery location before checking out!"
            }
        };

        window.currentLang = 'th';
        window.cart = [];
        window.isAdmin = false;
        window.activeShopIdForMenu = null;
        window.checkoutInterval = null;
        
        const locations = ["อาคาร 1", "อาคาร 2", "อาคาร 3", "อาคาร 4", "อาคาร 5", "อาคาร 6", "อาคาร 7", "อาคาร 8", "อาคาร 9", "อาคาร 10", "อาคาร 11", "สนามฟุตบอล"];

        const defaultShops = [
            { id: 1, nameTh: "ก๋วยเตี๋ยวป้าก.ไก่", nameEn: "Pa Kor Kai Noodles", img: "" },
            { id: 2, nameTh: "เบิ้ลสอง", nameEn: "Double Two", img: "" },
            { id: 3, nameTh: "ปั่นละมุน", nameEn: "Smooth Smoothie", img: "" },
            { id: 4, nameTh: "อร่อยเลิศกับป้ารี", nameEn: "Delicious Pa Ree", img: "" },
            { id: 5, nameTh: "เด็กอ้วน", nameEn: "Fat Boy", img: "" },
            { id: 6, nameTh: "เอกอิ่มอร่อย", nameEn: "Ek Im Aroy", img: "" },
            { id: 7, nameTh: "หวานเย็นทุกก้อน", nameEn: "Sweet Ice", img: "" },
            { id: 8, nameTh: "สุขเต็มชาม", nameEn: "Happy Bowl", img: "" },
            { id: 9, nameTh: "อ่อนแอ้น", nameEn: "On-An", img: "" },
            { id: 10, nameTh: "สถานีของทอด", nameEn: "Fried Station", img: "" },
            { id: 11, nameTh: "ชาบูเสียบไม้ล้าน 9", nameEn: "Shabu Skewer Lan 9", img: "" },
            { id: 12, nameTh: "ส้มตำคุณนาย", nameEn: "Madame Somtum", img: "" },
            { id: 13, nameTh: "ก๋วยเตี๋ยวน่องไก่ ราดหน้า ข้าวต้ม", nameEn: "Chicken Drumstick Noodles & Rad Na", img: "" },
            { id: 14, nameTh: "ข้าวราดแกง ไข่เจียวบุฟเฟ่ต์ สปาเก็ตตี้", nameEn: "Curry Rice & Omelet Buffet", img: "" }
        ];

        const defaultMenus = {
            1: [
                { id: 101, nameTh: "ก๋วยเตี๋ยวต้มยำทะเล", nameEn: "Seafood Tom Yum Noodles", price: 50, available: true },
                { id: 102, nameTh: "เส้นเล็กน้ำใสหมูสับ", nameEn: "Clear Soup Noodles with Pork", price: 40, available: true }
            ]
        };

        window.shopsData = defaultShops;
        window.menusData = defaultMenus;

        // ดึงค่าเก่าจาก LocalStorage
        try {
            const savedShops = localStorage.getItem('sriyapai_shops');
            if (savedShops) { window.shopsData = JSON.parse(savedShops); }
            const savedMenus = localStorage.getItem('sriyapai_menus');
            if (savedMenus) { window.menusData = JSON.parse(savedMenus); }
        } catch (e) { console.error("LocalStorage fallback loaded."); }

        function saveToLocalStorage() {
            try {
                localStorage.setItem('sriyapai_shops', JSON.stringify(window.shopsData));
                localStorage.setItem('sriyapai_menus', JSON.stringify(window.menusData));
            } catch(e) { console.error(e); }
        }

        // --- 2. GLOBAL COMPONENT FUNCTIONS ---
        window.updateLivePreview = function(url) {
            const previewBox = document.getElementById("imageLivePreviewBox");
            if (!previewBox) return;
            if (url && url.trim() !== "") {
                previewBox.innerHTML = `<img src="${url.trim()}" onerror="this.style.display='none'; document.getElementById('imageLivePreviewBox').innerHTML='<span style=\'color:red;font-size:14px;\'>❌ ลิงก์รูปภาพโหลดไม่ได้</span>'">`;
            } else {
                previewBox.innerHTML = `<span style="color:#aaa; font-size:14px;">แสดงตัวอย่างภาพตรงนี้ทันที</span>`;
            }
        };

        window.openEditShopModal = function(shopId) {
            const shop = window.shopsData.find(s => s.id === shopId);
            if (shop) {
                const idEl = document.getElementById("editShopId");
                const nameThEl = document.getElementById("editShopNameTh");
                const nameEnEl = document.getElementById("editShopNameEn");
                const imgEl = document.getElementById("editShopImg");
                
                if(idEl) idEl.value = shop.id;
                if(nameThEl) nameThEl.value = shop.nameTh;
                if(nameEnEl) nameEnEl.value = shop.nameEn;
                if(imgEl) imgEl.value = shop.img || "";
                
                window.updateLivePreview(shop.img || "");
                const modal = document.getElementById("editShopModal");
                if (modal) modal.style.display = "flex";
            }
        };

        window.openMenuModal = function(shopId) {
            window.activeShopIdForMenu = shopId;
            const shop = window.shopsData.find(s => s.id === shopId);
            if (!shop) return;
            
            const nameEl = document.getElementById("modalShopName");
            if (nameEl) nameEl.textContent = window.currentLang === 'th' ? shop.nameTh : shop.nameEn;

            const modalBody = document.getElementById("modalMenuBody");
            if (!modalBody) return;
            modalBody.innerHTML = "";

            const shopMenus = window.menusData[shopId] || [
                { id: 101, nameTh: "เมนูซิกเนเจอร์จานหลัก", nameEn: "Signature Main Dish", price: 45, available: true }
            ];

            shopMenus.forEach(item => {
                const itemName = window.currentLang === 'th' ? item.nameTh : item.nameEn;
                const statusClass = item.available ? 'status-available' : 'status-outofstock';
                const statusText = item.available ? i18n[window.currentLang].txt_available : i18n[window.currentLang].txt_outofstock;
                const disabledAttr = item.available ? '' : 'disabled';
                const cardClass = item.available ? 'menu-item-card' : 'menu-item-card out-of-stock';

                const menuCard = document.createElement("div");
                menuCard.className = cardClass;
                menuCard.innerHTML = `
                    <div class="menu-item-header">
                        <span>${itemName}</span>
                        <div>
                            <span style="margin-right:10px;">${item.price} ฿</span>
                            <span class="status-badge ${statusClass}">${statusText}</span>
                        </div>
                    </div>
                    ${item.available ? `
                    <div class="customization">
                        <div class="custom-group">
                            <label>${i18n[window.currentLang].label_spicy}</label>
                            <div class="custom-options">
                                <label><input type="radio" name="spicy_${item.id}" value="None" checked> ${i18n[window.currentLang].opt_no_spicy}</label>
                                <label><input type="radio" name="spicy_${item.id}" value="Medium"> ${i18n[window.currentLang].opt_mid_spicy}</label>
                                <label><input type="radio" name="spicy_${item.id}" value="High"> ${i18n[window.currentLang].opt_high_spicy}</label>
                            </div>
                        </div>
                        <div class="custom-options" style="margin-top:10px;">
                            <label><input type="checkbox" id="egg_${item.id}"> ${i18n[window.currentLang].label_egg}</label>
                            <label><input type="checkbox" id="noveg_${item.id}"> ${i18n[window.currentLang].label_no_veg}</label>
                            <label><input type="checkbox" id="noodle_${item.id}"> ${i18n[window.currentLang].label_more_noodle}</label>
                        </div>
                    </div>
                    ` : ''}
                    <button class="btn-primary btn-add-cart" ${disabledAttr} onclick="window.addItemToCart(${shopId}, ${item.id})">
                        ${i18n[window.currentLang].btn_add_to_cart}
                    </button>
                `;
                modalBody.appendChild(menuCard);
            });

            const menuModal = document.getElementById("menuModal");
            if (menuModal) menuModal.style.display = "flex";
        };

        window.addItemToCart = function(shopId, itemId) {
            const shop = window.shopsData.find(s => s.id === shopId);
            const shopMenus = window.menusData[shopId] || [
                { id: 101, nameTh: "เมนูซิกเนเจอร์จานหลัก", nameEn: "Signature Main Dish", price: 45, available: true }
            ];
            const item = shopMenus.find(m => m.id === itemId);
            if (!item || !shop) return;

            const spicyElem = document.querySelector(`input[name="spicy_${itemId}"]:checked`);
            const spicyVal = spicyElem ? spicyElem.value : "None";

            const eggElem = document.getElementById(`egg_${itemId}`);
            const addEgg = eggElem ? eggElem.checked : false;

            const vegElem = document.getElementById(`noveg_${itemId}`);
            const noVeg = vegElem ? vegElem.checked : false;

            const noodleElem = document.getElementById(`noodle_${itemId}`);
            const addNoodle = noodleElem ? noodleElem.checked : false;

            let finalPrice = item.price;
            let customNotes = [`Spicy: ${spicyVal}`];
            
            if(addEgg) { finalPrice += 10; customNotes.push("+Egg"); }
            if(noVeg) { customNotes.push("No Veg"); }
            if(addNoodle) { finalPrice += 10; customNotes.push("+Noodle"); }

            window.cart.push({
                cartId: Date.now() + Math.random().toString(36).slice(2, 7),
                shopTh: shop.nameTh, shopEn: shop.nameEn,
                nameTh: `${item.nameTh} (${customNotes.join(', ')})`,
                nameEn: `${item.nameEn} (${customNotes.join(', ')})`,
                price: finalPrice, quantity: 1
            });
            
            window.renderCart();
            const modal = document.getElementById("menuModal");
            if(modal) modal.style.display = "none";
            
            const cartSec = document.getElementById("cart-section");
            if(cartSec) cartSec.scrollIntoView({ behavior: 'smooth' });
        };

        window.removeItemFromCart = function(cartId) {
            window.cart = window.cart.filter(item => item.cartId !== cartId);
            window.renderCart();
        };

        window.renderCart = function() {
            const emptyMsg = document.getElementById("cartEmptyMessage");
            const content = document.getElementById("cartContent");
            const tbody = document.getElementById("cartItemsBody");

            if (!emptyMsg || !content || !tbody) return;

            if (window.cart.length === 0) {
                emptyMsg.style.display = "block"; content.style.display = "none"; return;
            }
            emptyMsg.style.display = "none"; content.style.display = "block"; tbody.innerHTML = "";

            let total = 0;
            window.cart.forEach(item => {
                const name = window.currentLang === 'th' ? item.nameTh : item.nameEn;
                const shopName = window.currentLang === 'th' ? item.shopTh : item.shopEn;
                total += item.price * item.quantity;

                const tr = document.createElement("tr");
                tr.innerHTML = `
                    <td><strong>${name}</strong></td>
                    <td>${shopName}</td>
                    <td>${item.price} ฿</td>
                    <td>${item.quantity}</td>
                    <td><button class="btn-delete" onclick="window.removeItemFromCart('${item.cartId}')">&times;</button></td>
                `;
                tbody.appendChild(tr);
            });
            const amtEl = document.getElementById("cartTotalAmount");
            if(amtEl) amtEl.textContent = total;
        };

        window.renderShops = function() {
            const grid = document.getElementById("shopsGrid");
            if (!grid) return;
            grid.innerHTML = "";

            window.shopsData.forEach(shop => {
                const name = window.currentLang === 'th' ? shop.nameTh : shop.nameEn;
                const btnText = i18n[window.currentLang].btn_select_menu;
                const imgSource = shop.img ? shop.img : `https://placehold.co/300x200/F2C94C/333333?text=${encodeURIComponent(name)}`;
                
                const card = document.createElement("div");
                card.className = "shop-card";
                card.innerHTML = `
                    <img src="${imgSource}" alt="${name}" class="shop-img">
                    <div class="shop-info">
                        <div class="shop-title">${name}</div>
                        <button class="btn-primary" onclick="window.openMenuModal(${shop.id})">${btnText}</button>
                        <button class="btn-primary btn-admin-edit admin-only" onclick="window.openEditShopModal(${shop.id})">⚙️ แก้ไขหน้าร้าน</button>
                    </div>
                `;
                grid.appendChild(card);
            });
        };

        window.updateLanguageDOM = function() {
            document.querySelectorAll("[data-i18n]").forEach(elem => {
                const key = elem.getAttribute("data-i18n");
                if(i18n[window.currentLang] && i18n[window.currentLang][key]) elem.textContent = i18n[window.currentLang][key];
            });
            document.querySelectorAll("[data-i18n-placeholder]").forEach(elem => {
                const key = elem.getAttribute("data-i18n-placeholder");
                if(i18n[window.currentLang] && i18n[window.currentLang][key]) elem.setAttribute("placeholder", i18n[window.currentLang][key]);
            });
        };

        // --- 3. DOMContentLoaded INITIALIZATION ---
        document.addEventListener("DOMContentLoaded", () => {
            // โหลด Dropdown สถานที่
            const select = document.getElementById("locationSelect");
            if (select) {
                select.innerHTML = `<option value="" disabled selected>-- เลือกสถานที่ / Select Location --</option>`;
                locations.forEach(loc => {
                    const opt = document.createElement("option");
                    opt.value = loc; opt.textContent = loc;
                    select.appendChild(opt);
                });
            }

            // ปุ่มเปลี่ยนภาษา
            const langToggle = document.getElementById("langToggle");
            if(langToggle) {
                langToggle.addEventListener("click", () => {
                    window.currentLang = window.currentLang === 'th' ? 'en' : 'th';
                    langToggle.textContent = window.currentLang === 'th' ? 'EN' : 'TH';
                    window.updateLanguageDOM();
                    window.renderShops();
                    window.renderCart();
                });
            }

            // ระบบแอดมิน ล็อกอิน/ล็อกเอาต์
            const loginBtn = document.getElementById("loginBtn");
            if(loginBtn) {
                loginBtn.addEventListener("click", () => {
                    if (window.isAdmin) {
                        window.isAdmin = false;
                        document.body.classList.remove("is-admin");
                        loginBtn.textContent = "Login";
                        loginBtn.classList.remove("logged-in");
                        const badge = document.getElementById("adminInfoBadge");
                        if(badge) badge.style.display = "none";
                        window.renderShops();
                    } else {
                        const lModal = document.getElementById("loginModal");
                        if(lModal) lModal.style.display = "flex";
                    }
                });
            }

            // ปิด Modal ต่าง ๆ
            const cLogin = document.getElementById("closeLoginModal");
            if(cLogin) cLogin.addEventListener("click", () => { const m = document.getElementById("loginModal"); if(m) m.style.display = "none"; });
            
            const cModal = document.getElementById("closeModal");
            if(cModal) cModal.addEventListener("click", () => { const m = document.getElementById("menuModal"); if(m) m.style.display = "none"; });
            
            const cEdit = document.getElementById("closeEditShopModal");
            if(cEdit) cEdit.addEventListener("click", () => { const m = document.getElementById("editShopModal"); if(m) m.style.display = "none"; });

            // ตรวจสอบความถูกต้องเพื่อเข้าสู่ระบบแอดมิน
            const submitLoginBtn = document.getElementById("submitLoginBtn");
            if (submitLoginBtn) {
                submitLoginBtn.addEventListener("click", () => {
                    const emailElem = document.getElementById("loginEmail");
                    const passElem = document.getElementById("loginPassword");
                    if (!emailElem || !passElem) return;

                    const email = emailElem.value.trim();
                    const pass = passElem.value.trim();
                    
                    // ปรับเปลี่ยนเงื่อนไขสิทธิ์เป็นข้อมูลชุดใหม่ของคุณอย่างแม่นยำ
                    if (email === "std49059@sriyapai.ac.th" && pass === "1869900778503") {
                        window.isAdmin = true;
                        document.body.classList.add("is-admin");
                        if(loginBtn) {
                            loginBtn.textContent = "Logout";
                            loginBtn.classList.add("logged-in");
                        }
                        const badge = document.getElementById("adminInfoBadge");
                        if(badge) badge.style.display = "block";
                        const lModal = document.getElementById("loginModal");
                        if(lModal) lModal.style.display = "none";
                        window.renderShops();
                        alert("เข้าสู่ระบบผู้ดูแลระบบสำเร็จแล้ว!");
                    } else {
                        alert("❌ ปฏิเสธการเข้าถึง! อีเมลหรือรหัสผ่านไม่ถูกต้อง");
                    }
                });
            }

            // บันทึกแก้ไขข้อมูลร้านค้า
            const saveShopBtn = document.getElementById("saveShopBtn");
            if(saveShopBtn) {
                saveShopBtn.addEventListener("click", () => {
                    const idVal = document.getElementById("editShopId") ? parseInt(document.getElementById("editShopId").value) : null;
                    const shop = window.shopsData.find(s => s.id === idVal);
                    if (shop) {
                        const thEl = document.getElementById("editShopNameTh");
                        const enEl = document.getElementById("editShopNameEn");
                        const imgEl = document.getElementById("editShopImg");

                        if(thEl) shop.nameTh = thEl.value;
                        if(enEl) shop.nameEn = enEl.value;
                        if(imgEl) shop.img = imgEl.value.trim();
                        
                        saveToLocalStorage();
                        window.renderShops(); 
                        const m = document.getElementById("editShopModal");
                        if(m) m.style.display = "none";
                    }
                });
            }

            // เพิ่มเมนูอาหารใหม่ (Admin)
            const addMenuBtn = document.getElementById("addMenuBtn");
            if(addMenuBtn) {
                addMenuBtn.addEventListener("click", () => {
                    const thVal = document.getElementById("newMenuTh") ? document.getElementById("newMenuTh").value.trim() : "";
                    const enVal = document.getElementById("newMenuEn") ? document.getElementById("newMenuEn").value.trim() : "";
                    const priceVal = document.getElementById("newMenuPrice") ? parseFloat(document.getElementById("newMenuPrice").value) : NaN;
                    const availVal = document.getElementById("newMenuAvailable") ? document.getElementById("newMenuAvailable").value === "true" : true;

                    if (!thVal || !enVal || isNaN(priceVal)) {
                        alert("กรุณากรอกข้อมูลเมนูอาหารให้ครบถ้วน");
                        return;
                    }

                    if (!window.menusData[window.activeShopIdForMenu]) window.menusData[window.activeShopIdForMenu] = [];

                    window.menusData[window.activeShopIdForMenu].push({
                        id: Date.now(), nameTh: thVal, nameEn: enVal, price: priceVal, available: availVal
                    });
                    
                    saveToLocalStorage();
                    window.openMenuModal(window.activeShopIdForMenu);

                    if(document.getElementById("newMenuTh")) document.getElementById("newMenuTh").value = "";
                    if(document.getElementById("newMenuEn")) document.getElementById("newMenuEn").value = "";
                    if(document.getElementById("newMenuPrice")) document.getElementById("newMenuPrice").value = "";
                });
            }

            // ปุ่มส่งคำสั่งซื้อและทำระบบจำลอง Tracking (Checkout)
            const checkoutBtn = document.getElementById("checkoutBtn");
            if(checkoutBtn) {
                checkoutBtn.addEventListener("click", () => {
                    const locSelect = document.getElementById("locationSelect") ? document.getElementById("locationSelect").value : "";
                    if(!locSelect) {
                        alert(i18n[window.currentLang].alert_location);
                        const sel = document.getElementById("locationSelect");
                        if(sel) sel.focus();
                        return;
                    }

                    if (window.checkoutInterval) clearInterval(window.checkoutInterval);
                    checkoutBtn.disabled = true;

                    const trackingSec = document.getElementById("tracking-section");
                    if(trackingSec) {
                        trackingSec.style.display = "block";
                        trackingSec.scrollIntoView({ behavior: 'smooth' });
                    }

                    const tActive = document.getElementById("trackingActive");
                    const tDone = document.getElementById("trackingDone");
                    if(tActive) tActive.style.display = "block";
                    if(tDone) tDone.style.display = "none";

                    const steps = ["step0", "step1", "step2", "step3"];
                    const statuses = ["Preparing...", "Cooking...", "Delivering...", "Completed"];
                    let currentStep = 0;

                    steps.forEach(s => {
                        const el = document.getElementById(s);
                        if(el) el.className = "step";
                    });
                    const pLine = document.getElementById("progressLineFill");
                    if(pLine) pLine.style.width = "0%";
                    const sText = document.getElementById("trackingStatusText");
                    if(sText) sText.textContent = statuses[0];
                    const s0 = document.getElementById("step0");
                    if(s0) s0.className = "step active";

                    window.checkoutInterval = setInterval(() => {
                        const curEl = document.getElementById(steps[currentStep]);
                        if(curEl) curEl.className = "step completed";
                        currentStep++;

                        if(currentStep < steps.length) {
                            const nextEl = document.getElementById(steps[currentStep]);
                            if(nextEl) nextEl.className = "step active";
                            const tx = document.getElementById("trackingStatusText");
                            if(tx) tx.textContent = statuses[currentStep];
                            let percent = (currentStep / (steps.length - 1)) * 100;
                            const pl = document.getElementById("progressLineFill");
                            if(pl) pl.style.width = `${percent}%`;
                        } else {
                            clearInterval(window.checkoutInterval);
                            const pl = document.getElementById("progressLineFill");
                            if(pl) pl.style.width = "100%";
                            setTimeout(() => {
                                if(tActive) tActive.style.display = "none";
                                if(tDone) tDone.style.display = "block";
                                checkoutBtn.disabled = false;
                                window.cart = []; 
                                window.renderCart();
                            }, 800);
                        }
                    }, 3000);
                });
            }

            // สั่งรันชุดแสดงผลครั้งแรก
            window.renderShops();
            window.updateLanguageDOM();
        });
    </script>
